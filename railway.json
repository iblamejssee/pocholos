{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "aptPkgs": [
            "wget",
            "gnupg",
            "libnss3",
            "libxss1",
            "libasound2",
            "libatk-bridge2.0-0",
            "libgtk-3-0",
            "libgbm-dev",
            "chromium",
            "fonts-liberation"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "node pocholo-bot.js",
    "restartPolicyType": "ON_FAILURE"
  }
}
